    "@logtail/pino": "^0.5.8",
    "@modelcontextprotocol/sdk": "^1.27.0",
    "@mozilla/readability": "^0.6.0",
    "@x402/core": "^2.10.0",
    "@x402/evm": "^2.10.0",
    "@x402/extensions": "^2.10.0",
    "@x402/hono": "^2.10.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.4",
    "franc": "^6.2.0",
    "hono": "^4.7.4",
    "jsdom": "^29.0.1",
    "libphonenumber-js": "^1.12.38",
    "p-limit": "^7.3.0",
    "pino": "^10.3.1",
    "postgres": "^3.4.5",
    "resend": "^6.9.4",
    "sharp": "^0.34.5",
    "strale-mcp": "*",
    "stripe": "^17.5.0",
    "turndown": "^7.2.2",
    "undici": "^7.0.0",
    "viem": "^2.47.6",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^22.12.0",
    "@types/turndown": "^5.0.6",
    "drizzle-kit": "^0.30.4",
    "js-yaml": "^4.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.4"
  }
